        </div>

        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-trash"></i> إعادة تعيين كل البيانات</div>
            <button onclick="resetAllData()" style="background:#ff4757; padding: 6px 15px; width: auto;">إعادة تعيين</button>
        </div>

        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-info-circle"></i> النسخة</div>
            <span>v2.1.0</span>
