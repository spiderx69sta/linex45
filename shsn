</div>

<!-- Modal للإعدادات -->
<div id="settingsModal" class="modal">
    <div class="modal-content">
        <h3 style="text-align: center;"><i class="fas fa-cog"></i> الإعدادات</h3>
        
        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-moon"></i> الوضع الليلي</div>
            <label class="switch"><input type="checkbox" id="darkModeToggle" onchange="toggleDarkMode()"><span class="slider"></span></label>
        </div>

        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-bell"></i> الإشعارات</div>
