        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-palette"></i> لون الخلفية</div>
            <div>
                <div class="color-option color-blue" onclick="changeBgColor('blue')"></div>
                <div class="color-option color-purple" onclick="changeBgColor('purple')"></div>
                <div class="color-option color-dark" onclick="changeBgColor('dark')"></div>
            </div>
