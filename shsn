<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dili Sora - منصة تخزين الصور</title>
<!-- خطوط متعددة -->
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Almarai:wght@400;700;800&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* الخطوط المتاحة */
body.font-cairo { font-family: 'Cairo', sans-serif; }
body.font-tajawal { font-family: 'Tajawal', sans-serif; }
body.font-almarai { font-family: 'Almarai', sans-serif; }
body.font-amiri { font-family: 'Amiri', serif; }

/* الصفحات */
.page {
    display: none;
    min-height: 100vh;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    background-attachment: fixed;
    padding: 20px;
    position: relative;
    transition: background 0.3s ease;
}

.page.active {
    display: block;
}

/* خلفيات الصفحة الثانية */
body.bg-blue .page,
.page.bg-blue {
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
}
body.bg-purple .page,
.page.bg-purple {
    background: linear-gradient(135deg, #1a0b2e, #3a1c6e, #2d1a4e);
}
body.bg-dark .page,
.page.bg-dark {
    background: linear-gradient(135deg, #0a0a0a, #1a1a2e, #0f0f1f);
}

.page::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
        radial-gradient(circle at 25% 50%, rgba(102, 126, 234, 0.08) 0%, transparent 50%),
        radial-gradient(circle at 75% 30%, rgba(118, 75, 162, 0.08) 0%, transparent 50%);
    pointer-events: none;
}

/* ========== الصفحة الأولى (تسجيل الدخول) ========== */
.login-container {
    max-width: 450px;
    margin: auto;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    padding: 35px 30px;
    border-radius: 35px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(102, 126, 234, 0.2);
}

.logo {
    width: 85px;
    height: 85px;
    margin: auto;
    border-radius: 28px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 38px;
    color: white;
    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
}

.title {
    text-align: center;
    margin-top: 12px;
    font-size: 28px;
    font-weight: 900;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.desc {
    text-align: center;
    color: #666;
    margin-top: 5px;
    margin-bottom: 25px;
    font-size: 14px;
}

.tabs {
    display: flex;
    background: #f0f0f5;
    border-radius: 50px;
    padding: 5px;
    margin-bottom: 25px;
}

.tabs button {
    flex: 1;
    border: none;
    padding: 12px;
    border-radius: 40px;
    background: none;
    font-weight: 800;
    font-size: 16px;
    cursor: pointer;
    transition: 0.3s;
}

.tabs .active {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.form {
    display: none;
}

.form.active {
    display: block;
    animation: fadeIn 0.4s ease;
}

.input-box {
    position: relative;
    margin-bottom: 18px;
}

.input-box i {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #667eea;
    font-size: 16px;
}

.input-box .toggle-password {
    left: 15px;
    right: auto;
    cursor: pointer;
}

.input-box input {
    width: 100%;
    padding: 14px 45px 14px 45px;
    border: 2px solid #e0e0e0;
    border-radius: 18px;
    outline: none;
    font-size: 15px;
    transition: 0.3s;
}

.input-box input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
}

.input-box input.error {
    border-color: #ff4757;
}

.error-msg {
    color: #ff4757;
    font-size: 12px;
    margin-top: 5px;
    margin-right: 10px;
    display: none;
}

.error-msg.show {
    display: block;
}

.main-btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 50px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    font-size: 17px;
    font-weight: 800;
    cursor: pointer;
    transition: 0.3s;
    margin-top: 5px;
}

.main-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
}

.features {
    display: flex;
    justify-content: space-around;
    margin-top: 30px;
    padding-top: 20px;
    border-top: 1px solid #eee;
}

.features i {
    font-size: 22px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* ========== الصفحة الثانية (المعرض) ========== */
.dashboard-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.header {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    border-radius: 32px;
    padding: 20px 32px;
    margin-bottom: 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
    box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(102, 126, 234, 0.2);
}

.logo h1 {
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: 28px;
    font-weight: 900;
}

.logo h1 i {
    background: none;
    -webkit-text-fill-color: #667eea;
    margin-left: 8px;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 20px;
}

.settings-btn {
    background: linear-gradient(135deg, #f5f7ff, #ffffff);
    border: 1px solid rgba(102, 126, 234, 0.2);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 22px;
    color: #667eea;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.settings-btn:hover {
    transform: rotate(30deg);
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.stats {
    display: flex;
    gap: 15px;
}

.stat-badge {
    background: linear-gradient(135deg, #f5f7ff, #ffffff);
    padding: 8px 20px;
    border-radius: 40px;
    font-weight: 800;
    color: #667eea;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(102, 126, 234, 0.15);
}

.controls-bar {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    border-radius: 28px;
    padding: 15px 24px;
    margin-bottom: 25px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
}

.sort-select {
    padding: 10px 20px;
    border-radius: 50px;
    border: 2px solid rgba(102, 126, 234, 0.2);
    background: white;
    font-weight: 600;
    cursor: pointer;
}

.create-folder-btn, .create-note-btn {
    background: linear-gradient(135deg, #667eea, #764ba2);
    border: none;
    padding: 10px 22px;
    border-radius: 50px;
    color: white;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.albums-section {
    margin-bottom: 30px;
    transition: all 0.3s ease;
}

.albums-section.hidden {
    display: none;
}

.albums-title {
    color: white;
    margin-bottom: 15px;
    font-size: 20px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 10px;
}

.albums-grid {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.album-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 16px 28px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s;
    min-width: 110px;
    border: 1px solid rgba(102, 126, 234, 0.2);
}

.album-card.active {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.album-card i {
    font-size: 32px;
    margin-bottom: 8px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.album-card.active i {
    -webkit-text-fill-color: white;
}

.gallery {
    display: grid;
    gap: 25px;
    margin-bottom: 30px;
}

.gallery.cols-3 { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
.gallery.cols-4 { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
.gallery.cols-5 { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }

.gallery-card {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-radius: 28px;
    overflow: hidden;
    transition: all 0.4s;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
}

.gallery-card:hover {
    transform: translateY(-8px);
}

.gallery-card img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    cursor: pointer;
}

.card-actions {
    padding: 14px;
    display: flex;
    justify-content: space-around;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
}

.card-actions button {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    padding: 8px;
    border-radius: 50%;
    transition: all 0.3s;
    width: 42px;
    height: 42px;
}

.card-actions button:hover {
    background: rgba(102, 126, 234, 0.1);
    transform: scale(1.1);
}

.download-btn { color: #28a745; }
.share-btn { color: #667eea; }
.delete-btn { color: #ff4757; }

.progress-container {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    border-radius: 60px;
    padding: 18px 30px;
    width: 340px;
    text-align: center;
    z-index: 1000;
    display: none;
}

.progress-bar {
    height: 8px;
    background: rgba(0, 0, 0, 0.1);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 12px;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    width: 0%;
    transition: width 0.3s ease;
}

.upload-area {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-radius: 32px;
    padding: 50px;
    text-align: center;
    border: 2px dashed #667eea;
    cursor: pointer;
    margin-bottom: 25px;
}

.preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 15px;
    margin-top: 20px;
}

/* Toast */
.toast-center {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 3000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
}

.toast-center.show {
    opacity: 1;
    visibility: visible;
}

.toast-card {
    background: white;
    padding: 35px 55px;
    border-radius: 60px;
    text-align: center;
    transform: scale(0.7);
    transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.toast-center.show .toast-card {
    transform: scale(1);
}

.animated-icon {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    margin: 0 auto 18px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: bouncePop 0.5s ease;
}

@keyframes bouncePop {
    0% { transform: scale(0); opacity: 0; }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
}

.lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.96);
    backdrop-filter: blur(15px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2000;
    visibility: hidden;
    opacity: 0;
    transition: all 0.3s;
}

.lightbox.show {
    visibility: visible;
    opacity: 1;
}

.lightbox img {
    max-width: 90%;
    max-height: 80%;
    border-radius: 24px;
}

.tabs-container {
    background: rgba(255, 255, 255, 0.98);
    border-radius: 60px;
    padding: 6px;
    margin-bottom: 25px;
    display: flex;
    gap: 6px;
}

.tab-btn {
    flex: 1;
    border: none;
    padding: 14px;
    border-radius: 50px;
    background: none;
    font-weight: 800;
    font-size: 16px;
    cursor: pointer;
    color: #555;
}

.tab-btn.active {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.tab-content {
    display: none;
    animation: fadeIn 0.4s ease;
}

.tab-content.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
}

.empty-message {
    background: rgba(255, 255, 255, 0.98);
    text-align: center;
    padding: 60px;
    border-radius: 35px;
    color: #888;
}

.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 4000;
    visibility: hidden;
}

.modal.show {
    visibility: visible;
}

.modal-content {
    background: white;
    padding: 35px;
    border-radius: 40px;
    width: 90%;
    max-width: 450px;
    max-height: 80vh;
    overflow-y: auto;
}

.setting-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid #eee;
}

.switch {
    position: relative;
    display: inline-block;
    width: 52px;
    height: 26px;
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.3s;
    border-radius: 34px;
}

.slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
}

input:checked + .slider {
    background: linear-gradient(135deg, #667eea, #764ba2);
}

input:checked + .slider:before {
    transform: translateX(26px);
}

.color-option {
    display: inline-flex;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    margin: 0 5px;
    cursor: pointer;
    border: 2px solid transparent;
}

.color-blue { background: linear-gradient(135deg, #0f0c29, #302b63, #24243e); }
.color-purple { background: linear-gradient(135deg, #1a0b2e, #3a1c6e, #2d1a4e); }
.color-dark { background: linear-gradient(135deg, #0a0a0a, #1a1a2e, #0f0f1f); }

.font-option {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: 30px;
    cursor: pointer;
    background: #f0f0f5;
    margin: 0 5px;
}

.font-option.active {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
}

.preview-item {
    position: relative;
    background: white;
    border-radius: 16px;
    padding: 6px;
}

.loading-spinner {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 50%;
    border-top-color: white;
    animation: spin 0.6s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}
</style>
</head>
<body>

<!-- الصفحة الأولى: تسجيل الدخول -->
<div id="loginPage" class="page active">
    <div class="login-container">
        <div class="logo">
            <i class="fas fa-cloud-moon"></i>
        </div>
        <div class="title">Dili Sora</div>
        <div class="desc">منصة تخزين الصور والملفات</div>

        <div class="tabs">
            <button id="loginBtn" class="active">تسجيل الدخول</button>
            <button id="registerBtn">إنشاء حساب</button>
        </div>

        <div id="loginForm" class="form active">
            <div class="input-box">
                <i class="fas fa-envelope"></i>
                <input type="email" id="loginEmail" placeholder="البريد الإلكتروني">
                <div class="error-msg" id="loginEmailError">بريد إلكتروني غير صحيح</div>
            </div>
            <div class="input-box">
                <i class="fas fa-lock"></i>
                <input type="password" id="loginPassword" placeholder="كلمة المرور">
                <i class="fas fa-eye toggle-password" onclick="togglePassword('loginPassword', this)"></i>
                <div class="error-msg" id="loginPassError">كلمة المرور مطلوبة</div>
            </div>
            <button class="main-btn" onclick="login()">تسجيل الدخول</button>
        </div>

        <div id="registerForm" class="form">
            <div class="input-box">
                <i class="fas fa-user"></i>
                <input type="text" id="regName" placeholder="الاسم الكامل">
                <div class="error-msg" id="regNameError">الاسم مطلوب</div>
            </div>
            <div class="input-box">
                <i class="fas fa-envelope"></i>
                <input type="email" id="regEmail" placeholder="البريد الإلكتروني">
                <div class="error-msg" id="regEmailError">بريد إلكتروني غير صحيح</div>
            </div>
            <div class="input-box">
                <i class="fas fa-lock"></i>
                <input type="password" id="regPassword" placeholder="كلمة المرور">
                <i class="fas fa-eye toggle-password" onclick="togglePassword('regPassword', this)"></i>
                <div class="error-msg" id="regPassError">كلمة المرور 6 أحرف على الأقل</div>
            </div>
            <div class="input-box">
                <i class="fas fa-lock"></i>
                <input type="password" id="regConfirmPassword" placeholder="تأكيد كلمة المرور">
                <i class="fas fa-eye toggle-password" onclick="togglePassword('regConfirmPassword', this)"></i>
                <div class="error-msg" id="regConfirmError">كلمتا المرور غير متطابقتين</div>
            </div>
            <button class="main-btn" onclick="register()">إنشاء الحساب</button>
        </div>

        <div class="features">
            <i class="fas fa-shield-alt"></i>
            <i class="fas fa-folder"></i>
            <i class="fas fa-image"></i>
            <i class="fas fa-cloud-upload-alt"></i>
        </div>
    </div>
</div>

<!-- الصفحة الثانية: المعرض -->
<div id="dashboardPage" class="page">
    <div class="dashboard-container">
        <div class="header">
            <div class="header-left">
                <div class="logo">
                    <h1><i class="fas fa-cloud-moon"></i> Dili Sora</h1>
                </div>
                <button class="settings-btn" onclick="openSettingsModal()"><i class="fas fa-cog"></i></button>
            </div>
            <div class="stats">
                <div class="stat-badge"><i class="fas fa-image"></i> <span id="fileCount">0</span> ملف</div>
                <div class="stat-badge"><i class="fas fa-folder"></i> <span id="albumCount">0</span> ألبوم</div>
                <div class="stat-badge"><i class="fas fa-user"></i> <span id="userNameDisplay"></span></div>
            </div>
        </div>

        <div class="tabs-container">
            <button class="tab-btn active" onclick="switchTab('gallery')"><i class="fas fa-images"></i> المعرض</button>
            <button class="tab-btn" onclick="switchTab('upload')"><i class="fas fa-cloud-upload-alt"></i> الرفع</button>
            <button class="tab-btn" onclick="switchTab('notes')"><i class="fas fa-pen-fancy"></i> الملاحظات</button>
        </div>

        <div id="galleryTab" class="tab-content active">
            <div class="controls-bar">
                <select id="sortSelect" class="sort-select" onchange="sortFiles()">
                    <option value="newest">✨ الأحدث أولاً</option>
                    <option value="oldest">📅 الأقدم أولاً</option>
                    <option value="largest">📦 الأكبر حجماً</option>
                </select>
                <button class="create-folder-btn" onclick="showCreateAlbumModal()"><i class="fas fa-folder-plus"></i> ألبوم جديد</button>
                <button class="create-note-btn" onclick="switchTab('notes')"><i class="fas fa-sticky-note"></i> ملاحظة جديدة</button>
                <button class="create-note-btn" onclick="logout()" style="background:#ff4757;"><i class="fas fa-sign-out-alt"></i> خروج</button>
