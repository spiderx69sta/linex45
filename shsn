<!-- Modal عادي -->
<div id="modal" class="modal">
    <div class="modal-content">
        <h3 id="modalTitle">إنشاء ألبوم</h3>
        <input type="text" id="modalInput" placeholder="الاسم">
        <textarea id="modalTextarea" style="display:none;" placeholder="محتوى الملاحظة"></textarea>
        <button onclick="confirmModal()"><i class="fas fa-check"></i> إنشاء</button>
        <button onclick="closeModal()" style="background:#ccc;"><i class="fas fa-times"></i> إلغاء</button>
    </div>
</div>

<script>
// ========== بيانات المستخدم ==========
let currentUser = null;

// ========== بيانات التطبيق ==========
let albums = [
    { id: 1, name: "الكل", isDefault: true },
    { id: 2, name: "الرحلات", isDefault: false },
    { id: 3, name: "العائلة", isDefault: false }
];
let currentAlbum = 1;
let files = [
    { id: 1, name: "غروب", size: 1.2, url: "https://picsum.photos/id/15/300/200", albumId: 1, date: new Date(2024,0,15) },
    { id: 2, name: "جبال", size: 2.1, url: "https://picsum.photos/id/104/300/200", albumId: 2, date: new Date(2024,1,20) },
    { id: 3, name: "بحر", size: 1.8, url: "https://picsum.photos/id/96/300/200", albumId: 2, date: new Date(2024,2,10) },
    { id: 4, name: "غابة", size: 2.5, url: "https://picsum.photos/id/13/300/200", albumId: 3, date: new Date(2024,3,5) }
];
let notes = [
    { id: 1, title: "مذكرة اجتماع", content: "اجتماع الساعة 10 صباحاً", date: new Date() }
];
let deletedFiles = [];

let pendingFiles = [];
let nextId = 5;
let nextAlbumId = 4;
let nextNoteId = 2;
let modalCallback = null;

// ========== دوال تسجيل الدخول ==========
function isValidEmail(email) {
    return /^[^\s@]+@([^\s@]+\.)+[^\s@]+$/.test(email);
}

function togglePassword(inputId, icon) {
    let input = document.getElementById(inputId);
    if (input.type === "password") {
        input.type = "text";
        icon.classList.replace("fa-eye", "fa-eye-slash");
    } else {
        input.type = "password";
        icon.classList.replace("fa-eye-slash", "fa-eye");
    }
}

function showCenterToast(title, message, isError = false) {
    const toast = document.getElementById("toastCenter");
    const toastTitle = document.getElementById("toastTitle");
    const toastMessage = document.getElementById("toastMessage");
    const iconDiv = document.getElementById("toastIcon");
    const icon = iconDiv.querySelector("i");
    
    toastTitle.textContent = title;
    toastMessage.textContent = message;
    
    if (isError) {
        iconDiv.style.background = "linear-gradient(135deg, #ff4757, #ff6b81)";
        icon.className = "fas fa-times";
    } else {
        iconDiv.style.background = "linear-gradient(135deg, #667eea, #764ba2)";
        icon.className = "fas fa-check";
    }
    
    toast.classList.add("show");
    setTimeout(() => toast.classList.remove("show"), 2500);
}

function login() {
    const email = document.getElementById("loginEmail").value.trim();
    const password = document.getElementById("loginPassword").value;
    
    if (!isValidEmail(email)) {
        showCenterToast("خطأ", "بريد إلكتروني غير صحيح", true);
        return;
    }
    if (!password) {
        showCenterToast("خطأ", "كلمة المرور مطلوبة", true);
        return;
    }
    
    currentUser = { name: email.split("@")[0], email: email };
    document.getElementById("userNameDisplay").innerText = currentUser.name;
    
    document.getElementById("loginPage").classList.remove("active");
    document.getElementById("dashboardPage").classList.add("active");
    
    renderAlbums();
    renderGallery();
    renderNotes();
    showCenterToast("تم تسجيل الدخول", `مرحباً ${currentUser.name} 👋`);
}

function register() {
    const name = document.getElementById("regName").value.trim();
    const email = document.getElementById("regEmail").value.trim();
    const password = document.getElementById("regPassword").value;
    const confirm = document.getElementById("regConfirmPassword").value;
    
    if (!name) {
        showCenterToast("خطأ", "الاسم الكامل مطلوب", true);
        return;
    }
    if (!isValidEmail(email)) {
        showCenterToast("خطأ", "بريد إلكتروني غير صحيح", true);
        return;
    }
    if (password.length < 6) {
        showCenterToast("خطأ", "كلمة المرور 6 أحرف على الأقل", true);
        return;
    }
    if (password !== confirm) {
        showCenterToast("خطأ", "كلمتا المرور غير متطابقتين", true);
        return;
    }
    
    showCenterToast("تم إنشاء الحساب", `مرحباً بك ${name} 🎉`);
    setTimeout(() => {
        document.getElementById("loginBtn").click();
        document.getElementById("loginEmail").value = email;
    }, 1500);
}

function logout() {
    currentUser = null;
    document.getElementById("dashboardPage").classList.remove("active");
    document.getElementById("loginPage").classList.add("active");
    document.getElementById("loginEmail").value = "";
    document.getElementById("loginPassword").value = "";
    showCenterToast("تم تسجيل الخروج", "نراكم قريباً 👋");
}

// ========== دوال التطبيق (نفس السابقة) ==========
function showNotification(title, body) {
    const notificationsOn = localStorage.getItem("notifications") !== "false";
    if (notificationsOn && Notification.permission === "granted") {
        new Notification(title, { body: body });
    } else if (notificationsOn && Notification.permission !== "denied") {
        Notification.requestPermission();
    }
}

function toggleNotifications() {
    const isChecked = document.getElementById("notificationsToggle").checked;
    localStorage.setItem("notifications", isChecked);
    showCenterToast("تم التحديث", isChecked ? "تفعيل الإشعارات" : "إيقاف الإشعارات");
}

function toggleDarkMode() {
    const isChecked = document.getElementById("darkModeToggle").checked;
    if (isChecked) {
        document.body.classList.add("dark-mode");
        localStorage.setItem("darkMode", "enabled");
    } else {
        document.body.classList.remove("dark-mode");
        localStorage.setItem("darkMode", "disabled");
    }
    showCenterToast("تم التحديث", isChecked ? "تفعيل الوضع الليلي" : "إيقاف الوضع الليلي");
}

function changeFont(fontName) {
    document.body.classList.remove("font-cairo", "font-tajawal", "font-almarai", "font-amiri");
    document.body.classList.add(`font-${fontName}`);
    localStorage.setItem("selectedFont", fontName);
    
    document.querySelectorAll(".font-option").forEach(opt => opt.classList.remove("active"));
    document.querySelector(`.font-option[data-font="${fontName}"]`).classList.add("active");
    
    let fontNames = { cairo: "Cairo", tajawal: "Tajawal", almarai: "Almarai", amiri: "Amiri" };
    showCenterToast("تم التحديث", `تم تغيير الخط إلى ${fontNames[fontName]}`);
}

function changeGallerySize() {
    const size = document.getElementById("gallerySizeSelect").value;
    const gallery = document.querySelector(".gallery");
    if (gallery) {
        gallery.classList.remove("cols-3", "cols-4", "cols-5");
        gallery.classList.add(`cols-${size}`);
    }
    localStorage.setItem("gallerySize", size);
    showCenterToast("تم التحديث", `تم تغيير حجم المعرض إلى ${size} صور بالصف`);
}

function toggleAlbums() {
    const isHidden = document.getElementById("hideAlbumsToggle").checked;
    const albumsSection = document.getElementById("albumsSection");
    if (isHidden) {
        albumsSection.classList.add("hidden");
        localStorage.setItem("hideAlbums", "true");
    } else {
        albumsSection.classList.remove("hidden");
        localStorage.setItem("hideAlbums", "false");
    }
    showCenterToast("تم التحديث", isHidden ? "إخفاء الألبومات" : "إظهار الألبومات");
}

function changeBgColor(color) {
    document.body.classList.remove("bg-blue", "bg-purple", "bg-dark");
    document.body.classList.add(`bg-${color}`);
    localStorage.setItem("bgColor", color);
    showCenterToast("تم التحديث", "تم تغيير لون الخلفية");
}

function clearDeletedFiles() {
    if (deletedFiles.length === 0) {
        showCenterToast("تنبيه", "سلة المحذوفات فارغة", true);
        return;
    }
    if (confirm("هل أنت متأكد من تفريغ سلة المحذوفات؟")) {
        deletedFiles = [];
        showCenterToast("تم التفريغ", "تم تفريغ سلة المحذوفات بنجاح");
    }
}

function exportData() {
    const exportBtn = document.getElementById("exportBtn");
    const originalText = exportBtn.innerHTML;
    exportBtn.innerHTML = '<span class="loading-spinner"></span> جاري التصدير...';
    exportBtn.disabled = true;
    
    setTimeout(() => {
        const data = { albums, files, notes, deletedFiles };
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = `dilisora_backup_${new Date().toISOString().slice(0,19)}.json`;
        link.click();
        exportBtn.innerHTML = originalText;
        exportBtn.disabled = false;
        showCenterToast("تم التصدير", "تم تصدير البيانات بنجاح ✅");
    }, 1000);
}

function resetAllData() {
    if (confirm("⚠️ تحذير: هذا الإجراء سيمسح كل البيانات؟")) {
        if (confirm("تأكيد نهائي: لا يمكن التراجع!")) {
            files = [];
            notes = [];
            albums = [{ id: 1, name: "الكل", isDefault: true }];
            deletedFiles = [];
            nextId = 5;
            nextAlbumId = 2;
            nextNoteId = 2;
            currentAlbum = 1;
            renderAlbums();
            renderGallery();
            renderNotes();
            showCenterToast("تم إعادة التعيين", "تم مسح كل البيانات بنجاح");
        }
    }
}

function updateStats() {
    document.getElementById("fileCount").innerText = files.filter(f => f.albumId === currentAlbum || currentAlbum === 1).length;
    document.getElementById("albumCount").innerText = albums.filter(a => !a.isDefault).length;
}

function renderAlbums() {
    const container = document.getElementById("albumsList");
    if (!container) return;
    container.innerHTML = albums.map(album => `
        <div class="album-card ${currentAlbum === album.id ? 'active' : ''}" onclick="selectAlbum(${album.id})">
            <i class="fas fa-${album.isDefault ? 'home' : 'folder'}"></i><br>
            ${album.name}
            ${!album.isDefault ? `<br><small onclick="event.stopPropagation();deleteAlbum(${album.id})" style="color:#ff4757; cursor:pointer;">🗑️</small>` : ''}
        </div>
    `).join("");
}

function selectAlbum(id) {
    currentAlbum = id;
    renderAlbums();
    renderGallery();
}

function deleteAlbum(id) {
    if (confirm("حذف الألبوم سينقل الملفات إلى 'الكل'")) {
        files.forEach(f => { if (f.albumId === id) f.albumId = 1; });
        albums = albums.filter(a => a.id !== id);
        if (currentAlbum === id) currentAlbum = 1;
        renderAlbums();
        renderGallery();
        showCenterToast("تم الحذف", "تم حذف الألبوم بنجاح");
    }
}

function sortFiles() {
    const sortBy = document.getElementById("sortSelect").value;
    const filtered = files.filter(f => f.albumId === currentAlbum || currentAlbum === 1);
    if (sortBy === "newest") filtered.sort((a,b) => b.date - a.date);
    else if (sortBy === "oldest") filtered.sort((a,b) => a.date - b.date);
    else if (sortBy === "largest") filtered.sort((a,b) => b.size - a.size);
    renderGallery(filtered);
}

function renderGallery(filteredList = null) {
    const container = document.getElementById("galleryContainer");
    if (!container) return;
    let displayFiles = filteredList || files.filter(f => f.albumId === currentAlbum || currentAlbum === 1);
    const savedSize = localStorage.getItem("gallerySize") || "4";
    
    if (displayFiles.length === 0) {
        container.innerHTML = `<div class="empty-message"><i class="fas fa-folder-open"></i><h3>لا توجد ملفات</h3><p>ارفع صورك الأولى الآن</p></div>`;
        updateStats();
        return;
    }
    container.innerHTML = `<div class="gallery cols-${savedSize}">${displayFiles.map(file => `
        <div class="gallery-card">
            <img src="${file.url}" onclick="openLightbox('${file.url}', '${file.name}')">
            <div class="card-actions">
                <button class="download-btn" onclick="downloadFile('${file.url}', '${file.name}')"><i class="fas fa-download"></i></button>
                <button class="share-btn" onclick="shareFile('${file.url}', '${file.name}')"><i class="fas fa-share-alt"></i></button>
                <button class="delete-btn" onclick="deleteFile(${file.id})"><i class="fas fa-trash"></i></button>
            </div>
        </div>
    `).join('')}</div>`;
    updateStats();
}

function openLightbox(url, name) {
    document.getElementById("lightboxImg").src = url;
    document.getElementById("lightboxDownloadBtn").onclick = () => downloadFile(url, name);
    document.getElementById("lightbox").classList.add("show");
}

function closeLightbox() {
    document.getElementById("lightbox").classList.remove("show");
}

function downloadFile(url, name) {
    const link = document.createElement("a");
    link.href = url;
    link.download = name + ".jpg";
    link.click();
    showCenterToast("جاري التحميل", `تحميل ${name}...`);
}

function shareFile(url, name) {
    navigator.clipboard.writeText(url);
    showCenterToast("تم المشاركة", `تم نسخ رابط ${name}`);
}

function deleteFile(id) {
    if (confirm("هل أنت متأكد من الحذف؟")) {
        const file = files.find(f => f.id === id);
        if (file) {
            files = files.filter(f => f.id !== id);
            deletedFiles.push(file);
            renderGallery();
            showCenterToast("تم الحذف", "تم نقل الملف إلى سلة المحذوفات");
        }
    }
}

function setupUpload() {
    const uploadArea = document.getElementById("uploadArea");
    const fileInput = document.getElementById("fileInput");
    if (!uploadArea) return;
    uploadArea.onclick = () => fileInput.click();
    fileInput.onchange = (e) => previewFiles(e.target.files);
    uploadArea.ondragover = (e) => { e.preventDefault(); uploadArea.style.borderColor = "#764ba2"; };
    uploadArea.ondragleave = () => uploadArea.style.borderColor = "#667eea";
    uploadArea.ondrop = (e) => { e.preventDefault(); previewFiles(e.dataTransfer.files); };
}

function previewFiles(filesList) {
    pendingFiles = [];
    const previewGrid = document.getElementById("previewGrid");
    previewGrid.innerHTML = "";
    Array.from(filesList).forEach(file => { if (file.type.startsWith("image/")) pendingFiles.push(file); });
    if (pendingFiles.length === 0) { showCenterToast("خطأ", "الرجاء اختيار صور فقط", true); return; }
    pendingFiles.forEach((file, idx) => {
        const reader = new FileReader();
        reader.onload = (e) => { previewGrid.innerHTML += `<div class="preview-item"><img src="${e.target.result}" style="width:100%; height:80px; object-fit:cover; border-radius:12px;"><div onclick="removePreview(${idx})" style="position:absolute; top:-6px; left:-6px; background:#ff4757; color:white; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer;">✕</div></div>`; };
        reader.readAsDataURL(file);
    });
    uploadFiles();
}

function removePreview(index) {
    pendingFiles.splice(index, 1);
    if (pendingFiles.length === 0) { document.getElementById("previewGrid").innerHTML = ""; document.getElementById("progressContainer").style.display = "none"; }
    else { previewFiles(pendingFiles); }
}

async function uploadFiles() {
    if (pendingFiles.length === 0) return;
    const progressDiv = document.getElementById("progressContainer");
    const progressFill = document.getElementById("progressFill");
    const progressPercent = document.getElementById("progressPercent");
    progressDiv.style.display = "block";
    for (let i = 0; i < pendingFiles.length; i++) {
        const percent = Math.round(((i + 1) / pendingFiles.length) * 100);
        progressFill.style.width = percent + "%";
        progressPercent.innerText = percent;
        await new Promise(resolve => setTimeout(resolve, 300));
        const file = pendingFiles[i];
        files.push({ id: nextId++, name: file.name.split('.')[0], size: (file.size / (1024 * 1024)).toFixed(1), url: URL.createObjectURL(file), albumId: currentAlbum, date: new Date() });
    }
    progressDiv.style.display = "none";
    pendingFiles = [];
    document.getElementById("previewGrid").innerHTML = "";
    renderGallery();
    showCenterToast("تم الرفع", "تم رفع الملفات بنجاح");
    showNotification("رفع الملفات", "تم رفع ملفاتك بنجاح");
}

function cancelUpload() { pendingFiles = []; document.getElementById("progressContainer").style.display = "none"; document.getElementById("previewGrid").innerHTML = ""; showCenterToast("تم الإلغاء", "تم إلغاء عملية الرفع", true); }

function renderNotes() {
    const container = document.getElementById("notesContainer");
    if (!container) return;
    const savedSize = localStorage.getItem("gallerySize") || "4";
    if (notes.length === 0) { container.innerHTML = `<div class="empty-message"><i class="fas fa-sticky-note"></i><h3>لا توجد ملاحظات</h3><p>أنشئ ملاحظتك الأولى</p></div>`; return; }
    container.innerHTML = `<div class="gallery cols-${savedSize}">${notes.map(note => `<div class="gallery-card"><div style="padding:20px;"><i class="fas fa-sticky-note" style="font-size:40px; color:#667eea;"></i><h3 style="margin:12px 0;">${note.title}</h3><p style="color:#666;">${note.content}</p><small>${note.date.toLocaleDateString('ar')}</small><div style="margin-top:15px;"><button onclick="deleteNote(${note.id})" style="background:#ff4757; color:white; border:none; padding:6px 15px; border-radius:25px; cursor:pointer;"><i class="fas fa-trash"></i> حذف</button></div></div></div>`).join('')}</div>`;
}

function deleteNote(id) { notes = notes.filter(n => n.id !== id); renderNotes(); showCenterToast("تم الحذف", "تم حذف الملاحظة"); }

function showCreateAlbumModal() {
    document.getElementById("modalTitle").innerText = "ألبوم جديد";
    document.getElementById("modalInput").style.display = "block";
    document.getElementById("modalTextarea").style.display = "none";
    document.getElementById("modalInput").value = "";
    modalCallback = () => { const name = document.getElementById("modalInput").value.trim(); if (name) { albums.push({ id: nextAlbumId++, name: name, isDefault: false }); renderAlbums(); showCenterToast("تم الإنشاء", `تم إنشاء ألبوم "${name}"`); } closeModal(); };
    document.getElementById("modal").classList.add("show");
}

function showCreateNoteModal() {
    document.getElementById("modalTitle").innerText = "ملاحظة جديدة";
    document.getElementById("modalInput").style.display = "block";
    document.getElementById("modalTextarea").style.display = "block";
    document.getElementById("modalInput").value = "";
    document.getElementById("modalTextarea").value = "";
    modalCallback = () => { const title = document.getElementById("modalInput").value.trim(); const content = document.getElementById("modalTextarea").value.trim(); if (title && content) { notes.push({ id: nextNoteId++, title: title, content: content, date: new Date() }); renderNotes(); showCenterToast("تم الإنشاء", `تم إنشاء ملاحظة "${title}"`); } closeModal(); };
    document.getElementById("modal").classList.add("show");
}

function confirmModal() { if (modalCallback) modalCallback(); }
function closeModal() { document.getElementById("modal").classList.remove("show"); modalCallback = null; }

function openSettingsModal() { document.getElementById("settingsModal").classList.add("show"); }
function closeSettingsModal() { document.getElementById("settingsModal").classList.remove("show"); }

function switchTab(tab) {
    document.getElementById("galleryTab").classList.remove("active");
    document.getElementById("uploadTab").classList.remove("active");
    document.getElementById("notesTab").classList.remove("active");
    document.getElementById(tab + "Tab").classList.add("active");
    document.querySelectorAll(".tab-btn").forEach(btn => btn.classList.remove("active"));
    if (tab === 'gallery') document.querySelector(".tab-btn:first-child").classList.add("active");
    if (tab === 'upload') document.querySelector(".tab-btn:nth-child(2)").classList.add("active");
    if (tab === 'notes') document.querySelector(".tab-btn:last-child").classList.add("active");
    if (tab === 'gallery') renderGallery();
    if (tab === 'notes') renderNotes();
}

// ========== التبديل بين تبويبات تسجيل الدخول ==========
document.getElementById("loginBtn").onclick = () => {
    document.getElementById("loginBtn").classList.add("active");
    document.getElementById("registerBtn").classList.remove("active");
    document.getElementById("loginForm").classList.add("active");
    document.getElementById("registerForm").classList.remove("active");
};

document.getElementById("registerBtn").onclick = () => {
    document.getElementById("registerBtn").classList.add("active");
    document.getElementById("loginBtn").classList.remove("active");
    document.getElementById("registerForm").classList.add("active");
    document.getElementById("loginForm").classList.remove("active");
};

// ========== استعادة الإعدادات ==========
if (localStorage.getItem("darkMode") === "enabled") {
    document.body.classList.add("dark-mode");
    document.getElementById("darkModeToggle").checked = true;
}
if (localStorage.getItem("notifications") === "false") {
    document.getElementById("notificationsToggle").checked = false;
}
if (localStorage.getItem("gallerySize")) {
    document.getElementById("gallerySizeSelect").value = localStorage.getItem("gallerySize");
}
if (localStorage.getItem("hideAlbums") === "true") {
    document.getElementById("hideAlbumsToggle").checked = true;
    document.getElementById("albumsSection").classList.add("hidden");
}
if (localStorage.getItem("bgColor")) {
    changeBgColor(localStorage.getItem("bgColor"));
}
const savedFont = localStorage.getItem("selectedFont");
if (savedFont) {
    changeFont(savedFont);
} else {
    document.querySelector(".font-option[data-font='cairo']")?.classList.add("active");
}

// ========== التشغيل ==========
setupUpload();
renderAlbums();
renderGallery();
renderNotes();
</script>
</body>
</html>
