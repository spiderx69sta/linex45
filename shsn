            <div class="albums-section" id="albumsSection">
                <div class="albums-title"><i class="fas fa-layer-group"></i> الألبومات</div>
                <div class="albums-grid" id="albumsList"></div>
            </div>

            <div id="galleryContainer"></div>
        </div>

        <div id="uploadTab" class="tab-content">
            <div class="upload-area" id="uploadArea">
                <i class="fas fa-cloud-upload-alt"></i>
                <h3 style="margin: 15px 0;">اسحب ملفاتك هنا</h3>
                <p style="color:#888;">أو اضغط للاختيار</p>
                <input type="file" id="fileInput" multiple accept="image/*" style="display:none;">
