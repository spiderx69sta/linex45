        </div>

        <div class="setting-item">
            <div class="setting-label"><i class="fas fa-font"></i> الخط</div>
            <div>
                <div class="font-option" data-font="cairo" onclick="changeFont('cairo')"><span>📝</span> Cairo</div>
                <div class="font-option" data-font="tajawal" onclick="changeFont('tajawal')"><span>📝</span> Tajawal</div>
                <div class="font-option" data-font="almarai" onclick="changeFont('almarai')"><span>📝</span> Almarai</div>
